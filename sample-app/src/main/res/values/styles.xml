<resources>

    <style name="SettingsChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textSize">16sp</item>
        <item name="android:minWidth">100dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">#000</item>
        <item name="chipBackgroundColor">@color/bg_chip_state_list</item>
        <item name="rippleColor">@color/bg_chip_ripple_color</item>
    </style>

    <style name="SampleAppButton" parent="spotim_core_t4_sb">
        <item name="textAllCaps">false</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:background">@drawable/button_background</item>
    </style>

    <style name="ToolbarViewButton" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">#FF000000</item>
        <item name="android:textSize">26sp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>

    <!-- Style with custom fontFamily, provided to OWSdk as a reference ID during initialization -->
    <style name="CustomFontStyle">
        <item name="android:fontFamily">@font/the_times_custom_font_family</item>
        <item name="fontFamily">@font/the_times_custom_font_family</item>
    </style>
    
    <!-- Theme for our test activity to demonstrate theme override issue -->
    <style name="PublisherCustomTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#FF5722</item>
        <item name="colorPrimaryDark">#E64A19</item>
        <item name="colorAccent">#4CAF50</item>
        <item name="android:textColor">#0000FF</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:windowBackground">#FFEB3B</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="behavior_fitToContents">true</item>
        <item name="behavior_hideable">true</item>
    </style>

    <!-- Custom Preference Dialog Theme -->
    <style name="PreferenceDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/colorAccent</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorAccent">@color/colorAccent</item>
        
        <!-- Dialog shape with rounded corners -->
        <item name="shapeAppearanceOverlay">@style/DialogShapeAppearance</item>
        
        <!-- Radio button style -->
        <item name="android:radioButtonStyle">@style/CustomRadioButton</item>
        
        <!-- Button styles -->
        <item name="buttonBarPositiveButtonStyle">@style/DialogPositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogNegativeButton</item>
        
        <!-- Dialog sizing -->
        <item name="android:windowMinWidthMajor">85%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <!-- Rounded corners for dialog -->
    <style name="DialogShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- Custom Radio Button -->
    <style name="CustomRadioButton" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:buttonTint">@color/colorAccent</item>
    </style>

    <!-- Positive button style (OK) -->
    <style name="DialogPositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Negative button style (CANCEL) -->
    <style name="DialogNegativeButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Preference Category Style -->
    <style name="PreferenceCategoryStyle" parent="Preference.Category.Material">
        <item name="android:layout">@layout/preference_category_material</item>
    </style>

    <!-- Preference Category Title Style -->
    <style name="PreferenceCategoryTitle" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:gravity">start</item>
    </style>

</resources>
